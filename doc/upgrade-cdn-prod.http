    //         "port": 443,
    //         "path": "/ota/axk_vb6824_v1.9_ota.bin",
    //         "tlsEnabled": true
    //     }
    // }
    import verifySuccessResult from './test'
    client.test('场景四：同场景三，省略 firmwareName 字段', verifySuccessResult);
%}
